# Frontend (Expo app)
# Web/Android emulator in WSL: localhost works.
# Physical phone with Expo Go: use your machine LAN IP (example below).
EXPO_PUBLIC_LLM_PROXY_URL=http://localhost:3001

# Local LLM proxy (never put this key in EXPO_PUBLIC_* vars)
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-3.0-flash-preview
LLM_PROXY_PORT=3001
LLM_PROXY_HOST=0.0.0.0

# Proxy authentication (shared secret between app and proxy)
LLM_PROXY_API_KEY=your-shared-secret-key-here
# Warning: EXPO_PUBLIC_* values are embedded client-side. Use a low-privilege key and rotate regularly.
EXPO_PUBLIC_LLM_PROXY_API_KEY=your-shared-secret-key-here

# Browser/CORS and proxy network trust hardening
# Comma-separated list of allowed browser origins for CORS. Defaults to localhost-only when unset.
LLM_PROXY_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
# Trust x-forwarded-for only when running behind a trusted reverse proxy.
LLM_PROXY_TRUST_X_FORWARDED_FOR=false

# Debug tooling endpoints (off by default)
LLM_PROXY_ENABLE_PLAYGROUND=false
LLM_PROXY_ENABLE_DEBUG_ENDPOINT=false

# Sentry crash reporting (opt-in, no PII)
# Runtime DSN used by the app
EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# WS1 required secret names for EAS/CI builds (set in EAS secrets, not committed):
# - SENTRY_AUTH_TOKEN
# - SENTRY_ORG
# - SENTRY_PROJECT
# - EXPO_PUBLIC_SENTRY_DSN
# Note: this app uses EXPO_PUBLIC_SENTRY_DSN at runtime and does not require SENTRY_DSN in source.
# Optional local vars for local EAS build flows:
SENTRY_ORG=citoyeninforme
SENTRY_PROJECT=citoyen-informe-mobile

# App environment for Sentry tagging (set via EAS profile env blocks for builds)
# Values: development, preview, production
# Local dev uses __DEV__ detection; this var is for distinguishing preview from production in EAS builds.
EXPO_PUBLIC_APP_ENV=development
# Optional: include screenshots/view hierarchy in crash reports (privacy-sensitive, disabled by default)
EXPO_PUBLIC_ENABLE_SENTRY_VISUAL_ATTACHMENTS=false

# Privacy policy URL (required for App Store / Play Store)
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://citoyeninforme.fr/politique-de-confidentialite
